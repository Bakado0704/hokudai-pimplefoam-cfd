injectionModel
{
    roomSeed
    {
        massInjected    1.88155e-07;
        nInjections     10;
        parcelsAddedTotal 7187;
        timeStep0       1;
    }
}

patchInteractionModel
{
    localInteraction
    {
        nEscape         4 ( 0 0 16 0 );
        massEscape      4 ( 0 0 4.18879e-10 0 );
        nStick          4 { 0 };
        massStick       4 { 0 };
    }
}


