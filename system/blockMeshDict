FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

// Room size: 6 m (x) x 15 m (y) x 2.8 m (z)

vertices
(
    (0 0 0)
    (6 0 0)
    (6 15 0)
    (0 15 0)
    (0 0 2.8)
    (6 0 2.8)
    (6 15 2.8)
    (0 15 2.8)
);

blocks
(
    // Maintain ~10 cells per meter in each direction
    hex (0 1 2 3 4 5 6 7) (60 150 28) simpleGrading (1 1 1)
);

boundary
(
    ceiling
    {
        type wall;
        faces ((4 5 6 7)); // ceiling z=2.8 (top now wall)
    }

    walls
    {
        type wall;
        faces
        (
            (0 4 7 3) // x=0 face becomes wall
            (0 1 5 4) // y=0 face (vertical)
            (3 7 6 2) // y=15 face (vertical)
            (0 3 2 1) // floor z=0
            (1 2 6 5) // x=6 face (side becomes wall)
        );
    }
);

mergePatchPairs();

