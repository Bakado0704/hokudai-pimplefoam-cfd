FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        // Door opening: passive inflow/outflow driven by pressure
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }

    outlet
    {
        // Exhaust: specify volumetric flow rate to pull air out
        type                flowRateOutletVelocity;
        volumetricFlowRate  constant 0.35; // 5ACH = 0.35 2.5ACH = 0.175 1ACH = 0.07
        value               uniform (0 0 0);
    }

    walls
    {
        type            noSlip;
    }

    ceiling
    {
        type            noSlip;
    }
}

